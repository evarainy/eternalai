# Python package mirror placeholders for pip/uv.
# PIP_INDEX_URL=https://example.invalid/pypi/simple
# UV_INDEX_URL=https://example.invalid/pypi/simple

# npm/pnpm registry placeholder. Prefer environment-local configuration.
# NPM_CONFIG_REGISTRY=https://example.invalid/npm/

# ── PostgreSQL (core-infra) ─────────────────────────────────────
POSTGRES_USER=eternalai
POSTGRES_PASSWORD=change_me
POSTGRES_DB=eternalai
POSTGRES_PORT=5432

# ── Redis (core-infra) ─────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Langfuse (observability) ────────────────────────────────────
LANGFUSE_PORT=3000
LANGFUSE_PUBLIC_KEY=placeholder_public_key
LANGFUSE_SECRET_KEY=placeholder_secret_key
LANGFUSE_NEXTAUTH_SECRET=placeholder_nextauth_secret
LANGFUSE_SALT=placeholder_salt

# ── OpenTelemetry Collector (observability) ─────────────────────
OTEL_COLLECTOR_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318

# ── App (app) ───────────────────────────────────────────────────
API_PORT=8000
FRONTEND_PORT=5173
