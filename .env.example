# Shared runtime configuration profile
APP_NAME=eternalai
APP_ENV=development
LOG_LEVEL=INFO

# API service
API_HOST=0.0.0.0
API_PORT=8000

# ASR service
ASR_HOST=0.0.0.0
ASR_PORT=8010
ASR_PROVIDER=sensevoice

# Shared infrastructure defaults
DATABASE_URL=postgresql://eternalai:eternalai@postgres:5432/eternalai
REDIS_URL=redis://redis:6379/0
WORKER_QUEUE=bootstrap

# Model configuration placeholders
LLM_PROVIDER=replace-with-provider
LLM_MODEL=replace-with-model-id
OPENAI_API_KEY=

# Client endpoints
WEB_BASE_URL=http://localhost:3001
MINIAPP_BASE_URL=http://localhost:3002

# Bootstrap auth mode
AUTH_MODE=disabled
